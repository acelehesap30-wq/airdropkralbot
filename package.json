{
  "name": "airdropkralbot",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node apps/admin-api/src/index.js",
    "start:admin": "node apps/admin-api/src/index.js",
    "start:bot": "node apps/bot/src/index.js",
    "start:all": "node scripts/start_render_single.js",
    "dev:bot": "node apps/bot/src/index.js",
    "dev:admin": "node apps/admin-api/src/index.js",
    "build:webapp": "npm run build --workspace @airdropkralbot/webapp",
    "sync:webapp:assets": "node scripts/webapp_sync_assets.mjs",
    "assets:webapp": "node scripts/generate_webapp_glb.mjs",
    "migrate:node": "node scripts/migrate_node.js",
    "test:bot": "node --test apps/bot/test/*.test.js",
    "test:admin-api": "node --test apps/admin-api/test/*.test.js",
    "typecheck:admin-api": "npx tsc -p apps/admin-api/tsconfig.json --noEmit",
    "typecheck:bot": "npx tsc -p apps/bot/tsconfig.json --noEmit",
    "typecheck:webapp": "npx tsc -p apps/webapp/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:admin-api && npm run typecheck:bot && npm run typecheck:webapp",
    "audit:v5.2": "node --check apps/admin-api/src/index.js && node --check packages/shared/src/v5/commandEngine.js && npm run test:bot",
    "validate:migrations:v5.2": "node scripts/validate_v5_2_migrations.mjs",
    "validate:migrations:v5.3": "node scripts/validate_v5_3_migrations.mjs",
    "smoke:v5.1": "powershell -ExecutionPolicy Bypass -File scripts/smoke_v5_1.ps1",
    "kpi:v5:snapshot": "node scripts/v5_kpi_snapshot.mjs",
    "kpi:v5:bundle": "node scripts/v5_kpi_bundle.mjs",
    "kpi:v5:weekly": "node scripts/v5_kpi_bundle.mjs --hours_short 24 --hours_long 72 --trend_days 7 --emit_slo true",
    "kpi:v5:daemon": "node scripts/v5_kpi_daemon.mjs --interval_min 360",
    "kpi:v5:task:check": "powershell -ExecutionPolicy Bypass -File scripts/check_v5_kpi_task.ps1",
    "kpi:v5:task:register": "powershell -ExecutionPolicy Bypass -File scripts/register_v5_kpi_tasks.ps1 -TaskName \"AirdropKralBot-V5-KPI-6H\" -EveryHours 6",
    "kpi:v5:task:remove": "powershell -ExecutionPolicy Bypass -File scripts/register_v5_kpi_tasks.ps1 -TaskName \"AirdropKralBot-V5-KPI-6H\" -UnregisterOnly",
    "check:release": "powershell -ExecutionPolicy Bypass -File scripts/check_release_readiness.ps1",
    "rollout:v4": "node scripts/v4_rollout_canary.mjs --stage admin",
    "rollout:v4:25": "node scripts/v4_rollout_canary.mjs --stage 25",
    "rollout:v4:100": "node scripts/v4_rollout_canary.mjs --stage 100",
    "rollback:v4": "node scripts/v4_rollback.mjs",
    "rollout:v5": "node scripts/v5_rollout_canary.mjs --stage admin",
    "rollout:v5:25": "node scripts/v5_rollout_canary.mjs --stage 25",
    "rollout:v5:100": "node scripts/v5_rollout_canary.mjs --stage 100",
    "rollback:v5": "node scripts/v5_rollback.mjs"
  }
}
