# NXT Token Deployment Config
# Copy this to .env and fill in your values

# Deployer wallet private key (keep secret!)
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# BscScan API key for contract verification (free at bscscan.com)
BSCSCAN_API_KEY=your_api_key

# Treasury address (receives initial 10M NXT + transfer taxes)
TREASURY_ADDRESS=0x_your_treasury_wallet

# After deployment — set these:
NXT_CONTRACT_ADDRESS=
NXT_CONTRACT_NETWORK=
NXT_CONTRACT_CHAIN_ID=

# Backend minter hot wallet (for addMinter.js script)
MINTER_ADDRESS=0x_your_backend_hot_wallet
